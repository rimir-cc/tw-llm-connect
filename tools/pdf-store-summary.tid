title: $:/plugins/rimir/llm-connect/tools/pdf-store-summary
tags: $:/tags/rimir/llm-connect/tool
tool-name: pdf_store_summary
tool-description: Store a summary of a PDF document. Creates a summary tiddler linked to the parent PDF with proper naming, metadata, and tags. Always use this tool to store summaries — do not return the summary as plain text.
tool-schema: {"type":"object","properties":{"parent_title":{"type":"string","description":"Title of the PDF tiddler being summarized"},"summary":{"type":"string","description":"The summary content in wikitext format with sections and bullet points"},"additional_requirements":{"type":"string","description":"Any additional requirements the user specified (empty string if none)"}},"required":["parent_title","summary"]}
tool-mode: action
tool-model-tier: expensive
tool-enabled: yes
tool-category: pdf
type: text/vnd.tiddlywiki

<$list filter="[<parent_title>minlength[1]]" variable="_" emptyMessage="Error: Missing 'parent_title' parameter">
<$list filter="[<summary>minlength[1]]" variable="_" emptyMessage="Error: Missing 'summary' parameter">
<$set name="summaryTitle" filter="[<parent_title>addsuffix[.summaries/]addsuffix<__model>addsuffix[-]addsuffix<__timestamp>]" select="0">
<$action-setfield $tiddler=<<summaryTitle>> text=<<summary>> parent=<<parent_title>> tags="llm-summary" summary-model=<<__model>> summary-timestamp=<<__timestamp>> additional-requirements=<<additional_requirements>> _artifact_source=<<parent_title>> _artifact_type="summary"/>
Done — created summary '<<summaryTitle>>'
</$set>
</$list>
</$list>
