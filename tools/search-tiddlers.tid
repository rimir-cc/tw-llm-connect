title: $:/plugins/rimir/llm-connect/tools/search-tiddlers
tags: $:/tags/rimir/llm-connect/tool
tool-name: search_tiddlers
tool-description: Search tiddlers using a TiddlyWiki filter expression. Returns matching titles and their fields (excluding text). Use filters like [tag[X]], [search[term]], [prefix[$:/]], etc.
tool-schema: {"type":"object","properties":{"filter":{"type":"string","description":"TiddlyWiki filter expression, e.g. [tag[Project]], [search[meeting]], [!is[system]sort[modified]last[10]]"}},"required":["filter"]}
tool-handler: filter
