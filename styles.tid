title: $:/plugins/rimir/llm-connect/styles
tags: $:/tags/Stylesheet
type: text/vnd.tiddlywiki

.llm-chat-container {
	display: flex;
	flex-direction: column;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 4px;
	overflow: hidden;
	max-height: 600px;
}

.llm-chat-messages {
	flex: 1;
	overflow-y: auto;
	padding: 8px;
	min-height: 200px;
	max-height: 400px;
	background: <<colour tiddler-background>>;
}

.llm-chat-message {
	margin: 4px 0;
	padding: 8px 12px;
	border-radius: 8px;
	max-width: 85%;
	word-wrap: break-word;
	white-space: pre-wrap;
	font-size: 0.9em;
	line-height: 1.4;
}

.llm-chat-message-user {
	background: <<colour primary>>;
	color: <<colour background>>;
	margin-left: auto;
	border-bottom-right-radius: 2px;
}

.llm-chat-message-assistant {
	background: <<colour tag-background>>;
	color: <<colour foreground>>;
	margin-right: auto;
	border-bottom-left-radius: 2px;
}

.llm-chat-message-context {
	background: <<colour code-background>>;
	color: <<colour muted-foreground>>;
	margin-left: auto;
	font-size: 0.8em;
	cursor: pointer;
	border: 1px dashed <<colour muted-foreground>>;
}

.llm-chat-message-context.llm-chat-context-expanded {
	font-size: 0.75em;
	color: <<colour code-foreground>>;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	max-height: 200px;
	overflow-y: auto;
	cursor: pointer;
}

.llm-chat-message-tool {
	background: <<colour code-background>>;
	color: <<colour code-foreground>>;
	margin-right: auto;
	font-size: 0.8em;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	border-left: 3px solid <<colour muted-foreground>>;
	border-radius: 0 8px 8px 0;
}

.llm-chat-status {
	display: none;
	padding: 4px 12px;
	font-size: 0.85em;
	color: <<colour muted-foreground>>;
	background: <<colour code-background>>;
	font-style: italic;
}

.llm-chat-input-area {
	border-top: 1px solid <<colour tiddler-border>>;
	padding: 8px;
	background: <<colour page-background>>;
}

.llm-chat-textarea {
	width: 100%;
	resize: vertical;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 4px;
	padding: 8px;
	font-size: 0.9em;
	font-family: inherit;
	background: <<colour tiddler-background>>;
	color: <<colour foreground>>;
	box-sizing: border-box;
}

.llm-chat-textarea:focus {
	outline: none;
	border-color: <<colour primary>>;
}

.llm-chat-button-row {
	display: flex;
	align-items: center;
	justify-content: flex-end;
	gap: 8px;
	margin-top: 6px;
}

.llm-chat-provider-info {
	font-size: 0.8em;
	color: <<colour muted-foreground>>;
	margin-right: auto;
}

.llm-chat-btn {
	padding: 4px 16px;
	border: none;
	border-radius: 4px;
	cursor: pointer;
	font-size: 0.85em;
}

.llm-chat-btn-send {
	background: <<colour primary>>;
	color: <<colour background>>;
}

.llm-chat-btn-send:hover {
	opacity: 0.9;
}

.llm-chat-btn-stop {
	background: <<colour dirty-indicator>>;
	color: <<colour background>>;
}

.llm-chat-panel {
	position: fixed;
	bottom: 20px;
	right: 20px;
	width: 480px;
	max-height: 70vh;
	background: <<colour tiddler-background>>;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 8px;
	box-shadow: 0 4px 20px rgba(0,0,0,0.15);
	z-index: 10000;
	display: flex;
	flex-direction: column;
	overflow: hidden;
}

.llm-chat-panel .llm-chat-container {
	max-height: none;
	border: none;
	flex: 1;
	overflow: hidden;
	display: flex;
	flex-direction: column;
}

.llm-chat-panel .llm-chat-messages {
	max-height: none;
	flex: 1;
	overflow-y: auto;
}

.llm-chat-panel-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 8px 12px;
	border-bottom: 1px solid <<colour tiddler-border>>;
	background: <<colour page-background>>;
	font-weight: bold;
	font-size: 0.9em;
	cursor: grab;
	user-select: none;
}

.llm-chat-panel-header:active {
	cursor: grabbing;
}

.llm-pair-edit-panel {
	margin-top: 12px;
	border: 2px solid <<colour primary>>;
	border-radius: 6px;
	overflow: hidden;
}

.llm-pair-edit-panel .llm-chat-container {
	max-height: none;
	border: none;
}

.llm-pair-edit-panel .llm-chat-messages {
	max-height: 300px;
}

.llm-pair-edit-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 6px 12px;
	background: <<colour primary>>;
	color: <<colour background>>;
	font-weight: bold;
	font-size: 0.85em;
}

.llm-tool-schema-input {
	min-height: 60px;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	font-size: 0.85em;
}

.llm-tool-body-input {
	min-height: 80px;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	font-size: 0.85em;
}

/* Tool list */
.llm-tool-table td {
	vertical-align: middle;
}

.llm-tool-toggle-cell {
	width: 1%;
	white-space: nowrap;
	padding-right: 0 !important;
}

.llm-tool-enabled-cell {
	width: 1%;
	text-align: center;
}

.llm-tool-actions-cell {
	width: 1%;
	white-space: nowrap;
}

.llm-tool-icon-btn {
	padding: 2px 4px;
	color: <<colour muted-foreground>>;
	vertical-align: middle;
}

.llm-tool-icon-btn:hover {
	color: <<colour foreground>>;
}

.llm-tool-row-disabled {
	opacity: 0.5;
}

.llm-tool-divider td {
	border-bottom: none !important;
	padding-top: 12px !important;
	padding-bottom: 2px !important;
	border-top: 2px solid <<colour tiddler-border>>;
}

.llm-tool-badge-read {
	background: <<colour primary>>;
	color: <<colour background>>;
}

.llm-tool-badge-action {
	background: #e67e22;
	color: #fff;
}

.llm-tool-badge-incomplete {
	background: <<colour muted-foreground>>;
	color: <<colour background>>;
	font-size: 0.75em;
}

.llm-tool-detail-cell {
	padding: 0 !important;
	background: <<colour page-background>>;
}

.llm-tool-detail {
	margin: 6px 6px 6px 24px;
	padding: 8px 12px;
	background: <<colour tiddler-background>>;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 4px;
	border-left: 3px solid <<colour primary>>;
}

.llm-tool-detail-section {
	margin-bottom: 6px;
}

.llm-tool-detail-section:last-child {
	margin-bottom: 0;
}

.llm-tool-detail-label {
	margin-bottom: 2px;
}

.llm-tool-detail-code {
	margin: 0;
	padding: 6px 8px;
	background: <<colour code-background>>;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 3px;
	font-size: 0.82em;
	white-space: pre-wrap;
	word-break: break-all;
	max-height: 200px;
	overflow-y: auto;
}
