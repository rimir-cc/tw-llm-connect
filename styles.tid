title: $:/plugins/rimir/llm-connect/styles
tags: $:/tags/Stylesheet
type: text/vnd.tiddlywiki

.llm-chat-container {
	display: flex;
	flex-direction: column;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 4px;
}

.llm-chat-messages {
	flex: 1;
	overflow-y: auto;
	padding: 8px;
	min-height: 200px;
	max-height: 400px;
	background: <<colour tiddler-background>>;
}

.llm-chat-message {
	margin: 4px 0;
	padding: 8px 12px;
	border-radius: 8px;
	max-width: 85%;
	word-wrap: break-word;
	white-space: pre-wrap;
	font-size: 0.9em;
	line-height: 1.4;
}

.llm-chat-message-user {
	background: <<colour primary>>;
	color: <<colour background>>;
	margin-left: auto;
	border-bottom-right-radius: 2px;
}

.llm-chat-message-assistant {
	background: <<colour tag-background>>;
	color: <<colour foreground>>;
	margin-right: auto;
	border-bottom-left-radius: 2px;
}

.llm-chat-message-context {
	background: <<colour code-background>>;
	color: <<colour muted-foreground>>;
	margin-left: auto;
	font-size: 0.8em;
	cursor: pointer;
	border: 1px dashed <<colour muted-foreground>>;
}

.llm-chat-message-context.llm-chat-context-expanded {
	font-size: 0.75em;
	color: <<colour code-foreground>>;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	max-height: 200px;
	overflow-y: auto;
	cursor: pointer;
}

.llm-chat-message-tool {
	background: <<colour code-background>>;
	color: <<colour code-foreground>>;
	margin-right: auto;
	font-size: 0.8em;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	border-left: 3px solid <<colour muted-foreground>>;
	border-radius: 0 8px 8px 0;
}

.llm-chat-status {
	display: none;
	padding: 4px 12px;
	font-size: 0.85em;
	color: <<colour muted-foreground>>;
	background: <<colour code-background>>;
	font-style: italic;
}

.llm-chat-input-area {
	border-top: 1px solid <<colour tiddler-border>>;
	padding: 8px;
	background: <<colour page-background>>;
}

.llm-chat-textarea {
	width: 100%;
	resize: vertical;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 4px;
	padding: 8px;
	font-size: 0.9em;
	font-family: inherit;
	background: <<colour tiddler-background>>;
	color: <<colour foreground>>;
	box-sizing: border-box;
}

.llm-chat-textarea:focus {
	outline: none;
	border-color: <<colour primary>>;
}

.llm-chat-button-row {
	display: flex;
	align-items: center;
	justify-content: flex-end;
	gap: 8px;
	margin-top: 6px;
}

.llm-chat-provider-info {
	font-size: 0.8em;
	color: <<colour muted-foreground>>;
	margin-right: auto;
}

.llm-chat-btn {
	padding: 4px 16px;
	border: none;
	border-radius: 4px;
	cursor: pointer;
	font-size: 0.85em;
}

.llm-chat-btn-send {
	background: <<colour primary>>;
	color: <<colour background>>;
}

.llm-chat-btn-send:hover {
	opacity: 0.9;
}

.llm-chat-btn-stop {
	background: <<colour dirty-indicator>>;
	color: <<colour background>>;
}

.llm-chat-panel {
	position: fixed;
	bottom: 20px;
	right: 20px;
	width: 480px;
	height: 70vh;
	min-height: 250px;
	min-width: 320px;
	background: <<colour tiddler-background>>;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 8px;
	box-shadow: 0 4px 20px rgba(0,0,0,0.15);
	z-index: 10000;
	display: flex;
	flex-direction: column;
	overflow: hidden;
	resize: both;
}

.llm-chat-panel .llm-chat-container {
	max-height: none;
	border: none;
	flex: 1 1 0%;
	min-height: 0;
	display: flex;
	flex-direction: column;
	overflow: hidden;
}

.llm-chat-panel .llm-chat-messages {
	flex: 1 1 0%;
	min-height: 100px;
	max-height: none;
	overflow-y: auto;
	resize: vertical;
}

.llm-chat-panel .llm-chat-debug-panel {
	flex: 1 1 0%;
	min-height: 80px;
	display: flex;
	flex-direction: column;
	overflow: hidden;
}

.llm-chat-panel .llm-chat-debug-content {
	max-height: none;
	flex: 1;
	min-height: 0;
	overflow-y: auto;
}

.llm-chat-panel-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 8px 12px;
	border-bottom: 1px solid <<colour tiddler-border>>;
	background: <<colour page-background>>;
	font-weight: bold;
	font-size: 0.9em;
	cursor: grab;
	user-select: none;
}

.llm-chat-panel-header:active {
	cursor: grabbing;
}

.llm-pair-edit-panel {
	margin-top: 12px;
	border: 2px solid <<colour primary>>;
	border-radius: 6px;
	overflow: hidden;
}

.llm-pair-edit-panel .llm-chat-container {
	max-height: none;
	border: none;
	display: flex;
	flex-direction: column;
}

.llm-pair-edit-panel .llm-chat-messages {
	max-height: 300px;
}

.llm-pair-edit-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 6px 12px;
	background: <<colour primary>>;
	color: <<colour background>>;
	font-weight: bold;
	font-size: 0.85em;
}

.llm-tool-schema-input {
	min-height: 60px;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	font-size: 0.85em;
}

.llm-tool-body-input {
	min-height: 80px;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	font-size: 0.85em;
}

/* Tool list */
.llm-tool-table td {
	vertical-align: middle;
}

.llm-tool-toggle-cell {
	width: 1%;
	white-space: nowrap;
	padding-right: 0 !important;
}

.llm-tool-enabled-cell {
	width: 1%;
	text-align: center;
}

.llm-tool-actions-cell {
	width: 1%;
	white-space: nowrap;
}

.llm-tool-icon-btn {
	padding: 2px 4px;
	color: <<colour muted-foreground>>;
	vertical-align: middle;
}

.llm-tool-icon-btn:hover {
	color: <<colour foreground>>;
}

.llm-tool-row-disabled {
	opacity: 0.5;
}

.llm-tool-divider td {
	border-bottom: none !important;
	padding-top: 12px !important;
	padding-bottom: 2px !important;
	border-top: 2px solid <<colour tiddler-border>>;
}

.llm-tool-badge-read {
	background: <<colour primary>>;
	color: <<colour background>>;
}

.llm-tool-badge-action {
	background: #e67e22;
	color: #fff;
}

.llm-tool-badge-incomplete {
	background: <<colour muted-foreground>>;
	color: <<colour background>>;
	font-size: 0.75em;
}

.llm-tool-detail-cell {
	padding: 0 !important;
	background: <<colour page-background>>;
}

.llm-tool-detail {
	margin: 6px 6px 6px 24px;
	padding: 8px 12px;
	background: <<colour tiddler-background>>;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 4px;
	border-left: 3px solid <<colour primary>>;
}

.llm-tool-detail-section {
	margin-bottom: 6px;
}

.llm-tool-detail-section:last-child {
	margin-bottom: 0;
}

.llm-tool-detail-label {
	margin-bottom: 2px;
}

.llm-tool-detail-code {
	margin: 0;
	padding: 6px 8px;
	background: <<colour code-background>>;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 3px;
	font-size: 0.82em;
	white-space: pre-wrap;
	word-break: break-all;
	max-height: 200px;
	overflow-y: auto;
}

/* Tool selector dropdown */
.llm-tool-selector-wrapper {
	position: relative;
	display: inline-block;
}

.llm-tool-selector-btn {
	padding: 2px 4px;
	vertical-align: middle;
}

.llm-tool-selector-dropdown {
	position: absolute;
	top: 100%;
	right: 0;
	z-index: 100;
	background: <<colour tiddler-background>>;
	color: <<colour foreground>>;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 4px;
	box-shadow: 0 2px 8px rgba(0,0,0,0.15);
	width: 220px;
	max-height: 300px;
	overflow-y: auto;
}

.llm-tool-selector-actions {
	display: flex;
	flex-wrap: wrap;
	gap: 4px;
	padding: 6px 8px;
	border-bottom: 1px solid <<colour tiddler-border>>;
}

.llm-tool-selector-action-btn {
	padding: 2px 8px;
	font-size: 0.8em;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 3px;
	background: <<colour page-background>>;
	cursor: pointer;
}

.llm-tool-selector-action-btn:hover {
	background: <<colour tag-background>>;
}

.llm-tool-selector-group-btn {
	border-color: <<colour primary>>;
	color: <<colour primary>>;
}

.llm-tool-selector-list {
	padding: 4px 8px;
}

.llm-tool-selector-item {
	display: block;
	padding: 2px 0;
	cursor: pointer;
	font-size: 0.85em;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.llm-tool-selector-item:hover {
	background: <<colour tag-background>>;
}

.llm-tool-selector-bar {
	margin-bottom: 4px;
}

/* Chat panel header actions */
.llm-chat-panel-header-actions {
	display: flex;
	align-items: center;
	gap: 4px;
}

/* Tool groups in settings */
.llm-group-entry {
	border-bottom: 1px solid <<colour tiddler-border>>;
	padding: 4px 0;
}

.llm-group-header {
	display: flex;
	align-items: center;
	gap: 8px;
}

.llm-group-detail {
	margin: 6px 0 6px 24px;
	padding: 8px 12px;
	background: <<colour tiddler-background>>;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 4px;
	border-left: 3px solid <<colour primary>>;
}

.llm-group-tools-grid {
	display: flex;
	flex-wrap: wrap;
	gap: 2px 12px;
}

.llm-group-tool-item {
	cursor: pointer;
	font-size: 0.85em;
	white-space: nowrap;
}

/* Model selector in chat */
.llm-model-selector-wrapper {
	position: relative;
	display: inline-block;
}

.llm-model-selector-btn {
	background: none;
	border: 1px solid transparent;
	border-radius: 3px;
	padding: 1px 6px;
	font-size: 0.8em;
	color: <<colour muted-foreground>>;
	cursor: pointer;
	white-space: nowrap;
}

.llm-model-selector-btn:hover {
	border-color: <<colour tiddler-border>>;
	color: <<colour foreground>>;
}

.llm-model-selector-btn-locked {
	opacity: 0.7;
}

.llm-model-selector-dropdown {
	position: absolute;
	bottom: 100%;
	left: 0;
	z-index: 100;
	background: <<colour tiddler-background>>;
	color: <<colour foreground>>;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 4px;
	box-shadow: 0 -2px 8px rgba(0,0,0,0.15);
	min-width: 200px;
	max-width: 350px;
	max-height: 300px;
	overflow-y: auto;
	padding: 4px 0;
}

.llm-model-selector-provider-header {
	padding: 4px 10px 2px;
	font-size: 0.75em;
	font-weight: bold;
	text-transform: uppercase;
	color: <<colour muted-foreground>>;
	letter-spacing: 0.05em;
}

.llm-model-selector-item {
	padding: 3px 10px;
	font-size: 0.82em;
	cursor: pointer;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.llm-model-selector-item:hover {
	background: <<colour tag-background>>;
}

.llm-model-selector-item-active {
	font-weight: bold;
}

.llm-model-selector-empty {
	padding: 8px 10px;
	font-size: 0.82em;
	color: <<colour muted-foreground>>;
	font-style: italic;
}

.llm-model-selector-fetch:hover {
	color: <<colour primary>>;
}

/* Token estimate label */
.llm-chat-token-label {
	font-size: 0.75em;
	color: <<colour muted-foreground>>;
	white-space: nowrap;
	opacity: 0.7;
}

/* Fetch models button in settings */
.llm-fetch-models-btn {
	margin-left: 8px;
	font-size: 0.85em;
	color: <<colour primary>>;
}

/* Clear chat button */
.llm-chat-btn-clear {
	background: none;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 3px;
	padding: 2px 8px;
	font-size: 0.8em;
	color: <<colour muted-foreground>>;
	cursor: pointer;
}

.llm-chat-btn-clear:hover {
	color: <<colour foreground>>;
	border-color: <<colour foreground>>;
}

/* Protection filter */
.llm-chat-protection-row {
	display: flex;
	align-items: center;
	gap: 6px;
	margin-top: 4px;
}

.llm-chat-protection-label {
	font-size: 0.8em;
	color: <<colour muted-foreground>>;
	white-space: nowrap;
}

.llm-chat-protection-input {
	flex: 1;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 3px;
	padding: 3px 6px;
	font-size: 0.8em;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	background: <<colour tiddler-background>>;
	color: <<colour foreground>>;
}

.llm-chat-protection-input:focus {
	outline: none;
	border-color: <<colour primary>>;
}

.llm-chat-btn-shield {
	background: none;
	border: none;
	cursor: pointer;
	font-size: 0.85em;
	padding: 1px 4px;
	opacity: 0.5;
}

.llm-chat-btn-shield:hover {
	opacity: 1;
}

/* Context filter */
.llm-chat-context-row {
	display: flex;
	align-items: center;
	gap: 6px;
	margin-top: 4px;
}

.llm-chat-context-label {
	font-size: 0.8em;
	color: <<colour muted-foreground>>;
	white-space: nowrap;
}

.llm-chat-context-input {
	flex: 1;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 3px;
	padding: 3px 6px;
	font-size: 0.8em;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	background: <<colour tiddler-background>>;
	color: <<colour foreground>>;
}

.llm-chat-context-input:focus {
	outline: none;
	border-color: <<colour primary>>;
}

.llm-chat-btn-context {
	background: none;
	border: none;
	cursor: pointer;
	font-size: 0.85em;
	padding: 1px 4px;
	opacity: 0.5;
}

.llm-chat-btn-context:hover {
	opacity: 1;
}

/* Debug panel */
.llm-chat-btn-debug {
	background: none;
	border: none;
	cursor: pointer;
	font-size: 0.85em;
	padding: 1px 4px;
	opacity: 0.35;
}

.llm-chat-btn-debug:hover {
	opacity: 0.8;
}

.llm-chat-debug-panel {
	margin-top: 6px;
	background: <<colour code-background>>;
	border: 1px solid <<colour tiddler-border>>;
	border-radius: 4px;
	font-size: 0.75em;
	color: <<colour foreground>>;
}

.llm-chat-debug-tabs {
	display: flex;
	border-bottom: 1px solid <<colour tiddler-border>>;
}

.llm-chat-debug-tab {
	padding: 4px 12px;
	border: none;
	background: none;
	cursor: pointer;
	font-size: 1em;
	color: <<colour muted-foreground>>;
	border-bottom: 2px solid transparent;
}

.llm-chat-debug-tab:hover {
	color: <<colour foreground>>;
}

.llm-chat-debug-tab-active {
	color: <<colour primary>>;
	border-bottom-color: <<colour primary>>;
}

.llm-chat-debug-content {
	padding: 8px;
	margin: 0;
	font-family: {{$:/themes/tiddlywiki/vanilla/settings/codefontfamily}};
	max-height: 300px;
	overflow-y: scroll;
	white-space: pre-wrap;
	word-break: break-all;
}
