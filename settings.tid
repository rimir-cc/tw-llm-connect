created: 20260310120000000
modified: 20260310120000000
title: $:/plugins/rimir/llm-connect/settings
type: text/vnd.tiddlywiki

\procedure llm-tool-row()
<$let
  detailState={{{ [[$:/state/rimir/llm-connect/tool-detail/]addsuffix<tool>] }}}
  editState={{{ [[$:/state/rimir/llm-connect/tool-edit/]addsuffix<tool>] }}}
  isEnabled={{{ [<tool>get[tool-enabled]else[yes]] }}}
  isComplete={{{ [<tool>get[tool-name]minlength[1]] [<tool>get[tool-schema]minlength[1]] [<tool>get[text]minlength[1]] +[count[]match[3]then[yes]else[no]] }}}
>
<tr class={{{ [<isEnabled>match[no]then[llm-tool-row-disabled]] [<isComplete>match[no]then[llm-tool-row-disabled]] +[first[]] }}}>
<td class="llm-tool-toggle-cell"><$button class="tc-btn-invisible llm-tool-toggle">
<$action-setfield $tiddler=<<detailState>> text={{{ [<detailState>get[text]match[open]then[closed]else[open]] }}}/>
<$reveal type="match" state=<<detailState>> text="open" tag="span">&#x25be;</$reveal><$reveal type="nomatch" state=<<detailState>> text="open" tag="span">&#x25b8;</$reveal>
</$button></td>
<td><code><$text text={{{ [<tool>get[tool-name]] }}}/></code><%if [<isComplete>match[no]] %> <span class="rr-badge-rect llm-tool-badge-incomplete">incomplete</span><%endif%></td>
<td><span class={{{ [<tool>get[tool-mode]match[action]then[rr-badge-rect llm-tool-badge-action]else[rr-badge-rect llm-tool-badge-read]] }}}><$text text={{{ [<tool>get[tool-mode]] }}}/></span></td>
<td><span class="rr-muted rr-small"><$text text={{{ [<tool>get[tool-model-tier]else[default]] }}}/></span></td>
<td><$text text={{{ [<tool>get[tool-description]] }}}/></td>
<td class="llm-tool-enabled-cell"><%if [<isComplete>match[yes]] %><$checkbox tiddler=<<tool>> field="tool-enabled" checked="yes" unchecked="no" default="yes"/><%endif%></td>
<td class="llm-tool-actions-cell">
<%if [<isComplete>match[yes]] %>
<$button class="tc-btn-invisible llm-tool-icon-btn" tooltip="Clone tool">
<$action-setfield $tiddler="$:/temp/rimir/llm-connect/new-tool-form" show="yes" new-title={{{ [<tool>addsuffix[/clone]] }}} tool-name={{{ [<tool>get[tool-name]addsuffix[_clone]] }}} tool-description={{{ [<tool>get[tool-description]addprefix[Clone of: ]] }}} tool-mode={{{ [<tool>get[tool-mode]] }}} tool-schema={{{ [<tool>get[tool-schema]] }}} tool-text={{{ [<tool>get[text]] }}} tool-enabled="no"/>
<$transclude $tiddler="$:/plugins/rimir/llm-connect/icon/copy"/>
</$button>
<%endif%>
<%if [<tool>!is[shadow]] %>
<$button class="tc-btn-invisible llm-tool-icon-btn" tooltip="Edit tool inline">
<$action-setfield $tiddler=<<detailState>> text={{{ [<editState>get[text]match[yes]then[open]else[open]] }}}/>
<$action-setfield $tiddler=<<editState>> text={{{ [<editState>get[text]match[yes]then[no]else[yes]] }}}/>
<$transclude $tiddler="$:/plugins/rimir/llm-connect/icon/edit"/>
</$button>
<%endif%>
</td>
</tr>
<$reveal type="match" state=<<detailState>> text="open" tag="tr">
<td colspan="7" class="llm-tool-detail-cell">
<div class="llm-tool-detail">
<$reveal type="nomatch" state=<<editState>> text="yes">
<div class="llm-tool-detail-section">
<div class="llm-tool-detail-label rr-muted rr-small">Tiddler</div>
<div><$link to=<<tool>>><$text text=<<tool>>/></$link></div>
</div>
<div class="llm-tool-detail-section">
<div class="llm-tool-detail-label rr-muted rr-small">Schema</div>
<pre class="llm-tool-detail-code"><$text text={{{ [<tool>get[tool-schema]] }}}/></pre>
</div>
<div class="llm-tool-detail-section">
<div class="llm-tool-detail-label rr-muted rr-small">Wikitext body</div>
<pre class="llm-tool-detail-code"><$text text={{{ [<tool>get[text]] }}}/></pre>
</div>
</$reveal>
<$reveal type="match" state=<<editState>> text="yes">
<div class="llm-tool-detail-section">
<div class="llm-tool-detail-label rr-muted rr-small">Tool name</div>
<$edit-text tiddler=<<tool>> field="tool-name" tag="input" class="rr-input" size="30"/>
</div>
<div class="llm-tool-detail-section">
<div class="llm-tool-detail-label rr-muted rr-small">Description</div>
<$edit-text tiddler=<<tool>> field="tool-description" tag="input" class="rr-input" size="60"/>
</div>
<div class="llm-tool-detail-section">
<div class="llm-tool-detail-label rr-muted rr-small">Mode</div>
<$select tiddler=<<tool>> field="tool-mode">
<option value="read">read</option>
<option value="action">action</option>
</$select>
</div>
<div class="llm-tool-detail-section">
<div class="llm-tool-detail-label rr-muted rr-small">Model tier</div>
<$select tiddler=<<tool>> field="tool-model-tier" default="default">
<option value="cheap">cheap</option>
<option value="default">default</option>
<option value="expensive">expensive</option>
</$select>
</div>
<div class="llm-tool-detail-section">
<div class="llm-tool-detail-label rr-muted rr-small">Schema (JSON)</div>
<$edit-text tiddler=<<tool>> field="tool-schema" tag="textarea" class="rr-textarea llm-tool-schema-input"/>
</div>
<div class="llm-tool-detail-section">
<div class="llm-tool-detail-label rr-muted rr-small">Wikitext body</div>
<$edit-text tiddler=<<tool>> field="text" tag="textarea" class="rr-textarea llm-tool-body-input"/>
</div>
</$reveal>
</div>
</td>
</$reveal>
</$let>
\end

!! Default model

<div class="rr-input-row">
<$select tiddler="$:/config/rimir/llm-connect/provider" field="text" default="claude" class="llm-default-model-provider-select">
<option value="claude">Claude (Anthropic)</option>
<option value="openai">OpenAI</option>
<option value="azure">Azure OpenAI</option>
</$select>
/
<$let curProvider={{{ [[$:/config/rimir/llm-connect/provider]get[text]else[claude]] }}} modelCache={{{ [[$:/temp/rimir/llm-connect/models/]addsuffix<curProvider>] }}} hasModels={{{ [<modelCache>get[text]minlength[3]then[yes]else[no]] }}}>
<$list filter="[<hasModels>match[no]]" variable="_">
<$edit-text tiddler={{{ [[$:/config/rimir/llm-connect/providers/]addsuffix<curProvider>addsuffix[/model]] }}} tag="input" default="" class="rr-input" size="30" placeholder="model id"/>
</$list>
<$list filter="[<hasModels>match[yes]]" variable="_">
<$select tiddler={{{ [[$:/config/rimir/llm-connect/providers/]addsuffix<curProvider>addsuffix[/model]] }}} default="">
<$list filter="[<modelCache>get[text]jsonindexes[]] :map[<modelCache>get[text]jsonget<currentTiddler>jsonget[id]]" variable="modelId">
<option value=<<modelId>>><$text text=<<modelId>>/></option>
</$list>
</$select>
</$list>
</$let>
<span class="rr-muted" style="margin-left:4px;">active provider + model for all chats</span>
</div>

!! Model tier routing

<span class="rr-muted rr-small">Route tool-use rounds to different models based on tool cost tier. When enabled, the orchestrator switches provider/model per iteration based on the highest tier among called tools. Disabled = all tools use the default model above.</span>

<div class="rr-input-row">
<$checkbox tiddler="$:/config/rimir/llm-connect/tier-routing-enabled" field="text" checked="yes" unchecked="no" default="no"/> Enable model tier routing
</div>

<$reveal type="match" state="$:/config/rimir/llm-connect/tier-routing-enabled" text="yes" animate="yes">
<div class="rr-input-row">
<strong>Cheap tier</strong> <span class="rr-muted rr-small">(search, get, render, navigate)</span><br/>
<$select tiddler="$:/config/rimir/llm-connect/tiers/cheap/provider" default="" class="rr-input">
<option value="">— select provider —</option>
<option value="claude">Claude</option>
<option value="openai">OpenAI</option>
<option value="azure">Azure</option>
</$select> /
<$edit-text tiddler="$:/config/rimir/llm-connect/tiers/cheap/model" tag="input" class="rr-input" size="30" placeholder="model id (e.g. gpt-4o-mini)"/>
</div>

<div class="rr-input-row">
<strong>Default tier</strong> <span class="rr-muted rr-small">(create, set, delete, attach)</span> — uses chat model above
</div>

<div class="rr-input-row">
<strong>Expensive tier</strong> <span class="rr-muted rr-small">(pdf summary, document analysis)</span><br/>
<$select tiddler="$:/config/rimir/llm-connect/tiers/expensive/provider" default="" class="rr-input">
<option value="">— select provider —</option>
<option value="claude">Claude</option>
<option value="openai">OpenAI</option>
<option value="azure">Azure</option>
</$select> /
<$edit-text tiddler="$:/config/rimir/llm-connect/tiers/expensive/model" tag="input" class="rr-input" size="30" placeholder="model id (e.g. claude-sonnet-4-20250514)"/>
</div>
</$reveal>

!! Providers

!!! Claude

<div class="rr-input-row">
API key: <$edit-text tiddler="$:/config/rimir/llm-connect/providers/claude/api-key" tag="input" default="" class="rr-input" size="40" type="password"/> <span class="rr-muted">stored in wiki</span>
</div>

<div class="rr-input-row">
Max tokens: <$edit-text tiddler="$:/config/rimir/llm-connect/providers/claude/max-tokens" tag="input" default="4096" class="rr-input" size="10"/>
<$button class="tc-btn-invisible llm-fetch-models-btn" tooltip="Fetch available models from API">
<$action-sendmessage $message="tm-llm-fetch-models" provider="claude"/>
&#x21bb; Fetch models
</$button>
<span class="rr-muted rr-small"><$text text={{{ [[$:/temp/rimir/llm-connect/fetch-status/claude]get[text]] }}}/></span>
</div>

!!! OpenAI

<div class="rr-input-row">
API key: <$edit-text tiddler="$:/config/rimir/llm-connect/providers/openai/api-key" tag="input" default="" class="rr-input" size="40" type="password"/> <span class="rr-muted">stored in wiki</span>
</div>

<div class="rr-input-row">
Max tokens: <$edit-text tiddler="$:/config/rimir/llm-connect/providers/openai/max-tokens" tag="input" default="4096" class="rr-input" size="10"/>
<$button class="tc-btn-invisible llm-fetch-models-btn" tooltip="Fetch available models from API">
<$action-sendmessage $message="tm-llm-fetch-models" provider="openai"/>
&#x21bb; Fetch models
</$button>
<span class="rr-muted rr-small"><$text text={{{ [[$:/temp/rimir/llm-connect/fetch-status/openai]get[text]] }}}/></span>
</div>

!!! Azure OpenAI

<div class="rr-input-row">
Endpoint: <$edit-text tiddler="$:/config/rimir/llm-connect/providers/azure/endpoint" tag="input" default="" class="rr-input" size="50" placeholder="https://myresource.openai.azure.com"/>
</div>

<div class="rr-input-row">
API key: <$edit-text tiddler="$:/config/rimir/llm-connect/providers/azure/api-key" tag="input" default="" class="rr-input" size="40" type="password"/> <span class="rr-muted">stored in wiki</span>
</div>

<div class="rr-input-row">
Deployment: <$edit-text tiddler="$:/config/rimir/llm-connect/providers/azure/deployment" tag="input" default="" class="rr-input" size="30" placeholder="my-gpt4o-deployment"/>
</div>

<div class="rr-input-row">
API version: <$edit-text tiddler="$:/config/rimir/llm-connect/providers/azure/api-version" tag="input" default="2025-04-01-preview" class="rr-input" size="15"/>
</div>

<div class="rr-input-row">
Max tokens: <$edit-text tiddler="$:/config/rimir/llm-connect/providers/azure/max-tokens" tag="input" default="4096" class="rr-input" size="10"/>
<$button class="tc-btn-invisible llm-fetch-models-btn" tooltip="Fetch available models from API">
<$action-sendmessage $message="tm-llm-fetch-models" provider="azure"/>
&#x21bb; Fetch models
</$button>
<span class="rr-muted rr-small"><$text text={{{ [[$:/temp/rimir/llm-connect/fetch-status/azure]get[text]] }}}/></span>
</div>

!! Safety

<$let
  modeTiddler="$:/config/rimir/llm-connect/protection-mode"
  protMode={{{ [[$:/config/rimir/llm-connect/protection-mode]get[text]else[allow]] }}}
  activeConfigTiddler={{{ [<protMode>match[allow]then[$:/config/rimir/llm-connect/allow-filter]else[$:/config/rimir/llm-connect/protection-filter]] }}}
  activeFilter={{{ [<activeConfigTiddler>get[text]] }}}
  isCustom={{{ [<activeConfigTiddler>is[tiddler]then[yes]else[no]] }}}
  baseProtFilter={{{ [[$:/config/rimir/llm-connect/base-protection-filter]get[text]] }}}
  baseProtIsCustom={{{ [[$:/config/rimir/llm-connect/base-protection-filter]is[tiddler]then[yes]else[no]] }}}
>

<div class="rr-input-row">
Base protection filter: <$edit-text tiddler="$:/config/rimir/llm-connect/base-protection-filter" tag="input" class="rr-input" size="50" placeholder="e.g. [tag[sensitive]]"/> <%if [<baseProtIsCustom>match[yes]] %><$button class="tc-btn-invisible rr-link-btn" style="font-size:inherit;" tooltip="Reset to default">
<$action-deletetiddler $tiddler="$:/config/rimir/llm-connect/base-protection-filter"/>
reset to default</$button><%endif%>
</div>
<div class="rr-input-row rr-small rr-muted">Part of the base filter — subtracted in allow mode, added in deny mode.</div>

<$let hardProtFilter={{{ [[$:/config/rimir/llm-connect/hard-protection-filter]get[text]] }}} hardProtIsCustom={{{ [[$:/config/rimir/llm-connect/hard-protection-filter]is[tiddler]then[yes]else[no]] }}}>
<div class="rr-input-row">
Hard protection filter: <$edit-text tiddler="$:/config/rimir/llm-connect/hard-protection-filter" tag="input" class="rr-input" size="50" placeholder="e.g. [tag[sensitive]]"/> <%if [<hardProtIsCustom>match[yes]] %><$button class="tc-btn-invisible rr-link-btn" style="font-size:inherit;" tooltip="Reset to default">
<$action-deletetiddler $tiddler="$:/config/rimir/llm-connect/hard-protection-filter"/>
reset to default</$button><%endif%>
</div>
<div class="rr-input-row rr-small rr-muted">Final safety net — applied after all user input (per-chat filters, drag-drop). Cannot be overridden. Tiddlers matching this filter are never accessible to the LLM.</div>
</$let>

<div class="rr-input-row">
Protection mode: <$select tiddler=<<modeTiddler>> default="allow" class="rr-input">
<option value="allow">Allow (whitelist) — only matching tiddlers are accessible</option>
<option value="deny">Deny (blacklist) — matching tiddlers are hidden from LLM</option>
</$select>
</div>

<div class="rr-input-row">
<%if [<protMode>match[allow]] %>Tiddler allow filter:<%else%>Tiddler deny filter:<%endif%> <$edit-text tiddler=<<activeConfigTiddler>> tag="input" class="rr-input" size="50" placeholder={{{ [<protMode>match[allow]then[e.g. [tag[public]] [prefix[Project/]]]else[e.g. [tag[sensitive]] [prefix[Private/]]]] }}}/> <%if [<isCustom>match[yes]] %><$button class="tc-btn-invisible rr-link-btn" style="font-size:inherit;" tooltip="Reset to default filter">
<$action-deletetiddler $tiddler=<<activeConfigTiddler>>/>
reset to default</$button><%endif%>
</div>

<div class="rr-input-row rr-small"><%if [<activeFilter>minlength[1]] %><%if [<isCustom>match[no]] %><span class="rr-muted">Active filter (default):</span><%else%><span class="rr-muted">Active filter (custom):</span><%endif%> <code><$text text=<<activeFilter>>/></code> — <%if [<protMode>match[allow]] %><strong><$text text={{{ [subfilter<activeFilter>count[]] }}}/></strong> tiddler(s) accessible (all others hidden)<%else%>protecting <strong><$text text={{{ [subfilter<activeFilter>count[]] }}}/></strong> tiddler(s)<%endif%>. <$button class="tc-btn-invisible rr-link-btn" style="font-size:inherit;">
<$action-setfield $tiddler="$:/state/rimir/llm-connect/show-protected" text={{{ [[$:/state/rimir/llm-connect/show-protected]get[text]match[yes]then[no]else[yes]] }}}/>
toggle list</$button>
<$reveal type="match" state="$:/state/rimir/llm-connect/show-protected" text="yes" animate="yes">
<div style="margin-top:4px;"><$list filter="[subfilter<activeFilter>sort[]]" variable="pt">
<$text text=<<pt>>/>, </$list></div>
</$reveal><%else%><%if [<protMode>match[allow]] %><span class="rr-muted">No allow filter defined — LLM has no access to any tiddlers.</span><%else%><span class="rr-muted">No deny filter active — all tiddlers are accessible to the LLM.</span><%endif%><%endif%>
</div>

!! Plugin visibility

<span class="rr-muted rr-small">Tick plugins to hide their shadow tiddlers from the LLM. Unticked = readable. Applied on top of the protection filter above.</span>

<div class="llm-excluded-plugins-grid">
<$list filter="[all[shadows+tiddlers]field:plugin-type[plugin]sort[title]]" variable="plugin">
<label class="llm-excluded-plugin-item">
<$checkbox tiddler="$:/config/rimir/llm-connect/excluded-plugins" listField="text" checked=<<plugin>>/> <$text text={{{ [<plugin>get[description]else<plugin>] }}}/> <span class="rr-muted rr-small">(<$text text={{{ [<plugin>removeprefix[$:/plugins/]] }}}/>)</span>
</label>
</$list>
</div>

</$let>

<div class="rr-input-row">
Max tool result length: <$edit-text tiddler="$:/config/rimir/llm-connect/max-tool-result-length" tag="input" default="4000" class="rr-input" size="10"/> <span class="rr-muted">characters — truncates long tool results to fit context</span>
</div>

<div class="rr-input-row">
Max file size: <$edit-text tiddler="$:/config/rimir/llm-connect/max-file-size" tag="input" default="20971520" class="rr-input" size="12"/> <span class="rr-muted">bytes — files larger than this are rejected (default 20MB)</span>
</div>

!! Document extraction

<span class="rr-muted rr-small">When enabled, PDF/DOCX/XLSX files are converted to markdown text via pandoc/python before sending to the LLM. Extracted text is cached per document. Requires the runner plugin and pandoc on the server.</span>

<div class="rr-input-row">
<$checkbox tiddler="$:/config/rimir/llm-connect/extraction-enabled" field="text" checked="yes" unchecked="no" default="yes"/> Enable document extraction <span class="rr-muted">(uses extracted text instead of base64 — major token savings)</span>
</div>

<div class="rr-input-row">
Max extraction size: <$edit-text tiddler="$:/config/rimir/llm-connect/max-extraction-size" tag="input" default="500000" class="rr-input" size="10"/> <span class="rr-muted">characters — truncates extracted text beyond this limit</span>
</div>

!! Context

<div class="rr-input-row">
Default context template: <$edit-text tiddler="$:/config/rimir/llm-connect/default-context-template" tag="input" default="" class="rr-input" size="50"/> <span class="rr-muted">leave empty for built-in default (render source tiddler text)</span>
</div>

!! System prompt

<$edit-text tiddler="$:/config/rimir/llm-connect/system-prompt" class="rr-textarea" tag="textarea" default="You are a helpful TiddlyWiki assistant. You can search, read, and modify tiddlers using the available tools."/>

!! Tools

<$let newToolState="$:/temp/rimir/llm-connect/new-tool-form">

<table class="rr-table llm-tool-table">
<tr><th></th><th>Name</th><th>Mode</th><th>Tier</th><th>Description</th><th>Active</th><th>Actions</th></tr>
<$list filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]is[shadow]sort[tool-name]]" variable="tool">
<<llm-tool-row>>
</$list>
<$list filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!is[shadow]limit[1]]" variable="_">
<tr class="llm-tool-divider"><td colspan="7"><span class="rr-muted rr-small">Custom tools</span></td></tr>
</$list>
<$list filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!is[shadow]sort[tool-name]]" variable="tool">
<<llm-tool-row>>
</$list>
</table>

<$reveal type="nomatch" stateTitle=<<newToolState>> stateField="show" text="yes">
<$button class="tc-btn-big-green" style="margin-top:8px;">
<$action-setfield $tiddler=<<newToolState>> show="yes" tool-name="" tool-description="" tool-mode="read" tool-schema='{&#34;type&#34;:&#34;object&#34;,&#34;properties&#34;:{},&#34;required&#34;:[]}' tool-text="" new-title="" tool-enabled="no"/>
Create new tool
</$button>
</$reveal>

<$reveal type="match" stateTitle=<<newToolState>> stateField="show" text="yes" animate="yes">
<div class="llm-tool-form rr-panel" style="margin-top:8px;">
<div class="rr-panel-body">

<div class="rr-input-row">
Tiddler title: <$edit-text tiddler=<<newToolState>> field="new-title" tag="input" class="rr-input" size="50" placeholder="$:/my-tools/tool-name"/>
</div>

<div class="rr-input-row">
Tool name: <$edit-text tiddler=<<newToolState>> field="tool-name" tag="input" class="rr-input" size="30" placeholder="my_tool_name"/> <span class="rr-muted">identifier sent to LLM (e.g. `get_tagged`)</span>
</div>

<div class="rr-input-row">
Description: <$edit-text tiddler=<<newToolState>> field="tool-description" tag="input" class="rr-input" size="50" placeholder="What this tool does"/>
</div>

<div class="rr-input-row">
Mode: <$select tiddler=<<newToolState>> field="tool-mode" default="read">
<option value="read">read — render wikitext, return text output</option>
<option value="action">action — execute action widgets + return confirmation</option>
</$select>
Model tier: <$select tiddler=<<newToolState>> field="tool-model-tier" default="default">
<option value="cheap">cheap</option>
<option value="default">default</option>
<option value="expensive">expensive</option>
</$select>
</div>

<div class="rr-input-row">
Schema (JSON):
<$edit-text tiddler=<<newToolState>> field="tool-schema" tag="textarea" class="rr-textarea llm-tool-schema-input" placeholder='{"type":"object","properties":{"param":{"type":"string"}},"required":["param"]}'/>
</div>

<div class="rr-input-row">
Wikitext body:
<$edit-text tiddler=<<newToolState>> field="tool-text" tag="textarea" class="rr-textarea llm-tool-body-input" placeholder="<$list filter=<<param>>>..."/>
</div>

<div class="rr-input-row" style="display:flex;gap:8px;justify-content:flex-end;">
<$button class="tc-btn-big-green">
<$let targetTitle={{{ [<newToolState>get[new-title]] }}}>
<$action-setfield
  $tiddler=<<targetTitle>>
  tool-name={{{ [<newToolState>get[tool-name]] }}}
  tool-description={{{ [<newToolState>get[tool-description]] }}}
  tool-mode={{{ [<newToolState>get[tool-mode]] }}}
  tool-schema={{{ [<newToolState>get[tool-schema]] }}}
  tool-enabled={{{ [<newToolState>get[tool-enabled]] }}}
  tool-model-tier={{{ [<newToolState>get[tool-model-tier]] }}}
  text={{{ [<newToolState>get[tool-text]] }}}
  type="text/vnd.tiddlywiki"
/>
<$action-listops $tiddler=<<targetTitle>> $tags="$:/tags/rimir/llm-connect/tool"/>
</$let>
<$action-deletetiddler $tiddler=<<newToolState>>/>
Create
</$button>
<$button>
<$action-deletetiddler $tiddler=<<newToolState>>/>
Cancel
</$button>
</div>

</div>
</div>
</$reveal>

</$let>

!! Tool Groups

<span class="rr-muted">Groups are presets that can be applied in the per-chat tool selector to quickly switch between tool sets.</span>

<$list filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool-group]sort[group-name]]" variable="group" emptyMessage="">
<$let groupDetailState={{{ [[$:/state/rimir/llm-connect/group-detail/]addsuffix<group>] }}}>
<div class="llm-group-entry">
<div class="llm-group-header">
<$button class="tc-btn-invisible llm-tool-toggle">
<$action-setfield $tiddler=<<groupDetailState>> text={{{ [<groupDetailState>get[text]match[open]then[closed]else[open]] }}}/>
<$reveal type="match" state=<<groupDetailState>> text="open" tag="span">&#x25be;</$reveal><$reveal type="nomatch" state=<<groupDetailState>> text="open" tag="span">&#x25b8;</$reveal>
</$button>
<strong><$text text={{{ [<group>get[group-name]] }}}/></strong>
<span class="rr-muted rr-small">(<$text text={{{ [<group>get[group-tools]enlist-input[]count[]] }}}/> tools)</span>
<$button class="tc-btn-invisible llm-tool-icon-btn rr-link-btn-danger" tooltip="Delete group">
<$action-confirm $message="Delete this tool group?">
<$action-deletetiddler $tiddler=<<group>>/>
</$action-confirm>
<$transclude $tiddler="$:/plugins/rimir/llm-connect/icon/delete"/>
</$button>
</div>
<$reveal type="match" state=<<groupDetailState>> text="open" animate="yes">
<div class="llm-group-detail">
<div class="rr-input-row">
Name: <$edit-text tiddler=<<group>> field="group-name" tag="input" class="rr-input" size="30"/>
</div>
<div class="rr-input-row">
Description: <$edit-text tiddler=<<group>> field="group-description" tag="input" class="rr-input" size="50"/>
</div>
<div class="llm-group-tools-grid">
<$list filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]sort[tool-name]]" variable="tool">
<label class="llm-group-tool-item" title={{{ [<tool>get[tool-description]] }}}>
<$checkbox tiddler=<<group>> listField="group-tools" checked=<<tool>>/> <$text text={{{ [<tool>get[tool-name]] }}}/>
</label>
</$list>
</div>
</div>
</$reveal>
</div>
</$let>
</$list>

<$let newGroupState="$:/temp/rimir/llm-connect/new-group-form">

<$reveal type="nomatch" stateTitle=<<newGroupState>> stateField="show" text="yes">
<$button class="tc-btn-big-green" style="margin-top:8px;">
<$action-setfield $tiddler=<<newGroupState>> show="yes" group-name="" group-description="" new-title="" group-tools=""/>
Create new group
</$button>
</$reveal>

<$reveal type="match" stateTitle=<<newGroupState>> stateField="show" text="yes" animate="yes">
<div class="llm-tool-form rr-panel" style="margin-top:8px;">
<div class="rr-panel-body">

<div class="rr-input-row">
Tiddler title: <$edit-text tiddler=<<newGroupState>> field="new-title" tag="input" class="rr-input" size="50" placeholder="$:/config/rimir/llm-connect/groups/my-group"/>
</div>

<div class="rr-input-row">
Group name: <$edit-text tiddler=<<newGroupState>> field="group-name" tag="input" class="rr-input" size="30" placeholder="My Group"/>
</div>

<div class="rr-input-row">
Description: <$edit-text tiddler=<<newGroupState>> field="group-description" tag="input" class="rr-input" size="50" placeholder="Optional description"/>
</div>

<div class="rr-input-row">Tools:</div>
<div class="llm-group-tools-grid">
<$list filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]sort[tool-name]]" variable="tool">
<label class="llm-group-tool-item" title={{{ [<tool>get[tool-description]] }}}>
<$checkbox tiddler=<<newGroupState>> listField="group-tools" checked=<<tool>>/> <$text text={{{ [<tool>get[tool-name]] }}}/>
</label>
</$list>
</div>

<div class="rr-input-row" style="display:flex;gap:8px;justify-content:flex-end;">
<$button class="tc-btn-big-green">
<$let targetTitle={{{ [<newGroupState>get[new-title]] }}}>
<$action-setfield
  $tiddler=<<targetTitle>>
  group-name={{{ [<newGroupState>get[group-name]] }}}
  group-description={{{ [<newGroupState>get[group-description]] }}}
  group-tools={{{ [<newGroupState>get[group-tools]] }}}
/>
<$action-listops $tiddler=<<targetTitle>> $tags="$:/tags/rimir/llm-connect/tool-group"/>
</$let>
<$action-deletetiddler $tiddler=<<newGroupState>>/>
Create
</$button>
<$button>
<$action-deletetiddler $tiddler=<<newGroupState>>/>
Cancel
</$button>
</div>

</div>
</div>
</$reveal>

</$let>
