title: $:/plugins/rimir/llm-connect/ui/pair-edit-panel
tags: $:/tags/ViewTemplate
list-after: $:/core/ui/ViewTemplate/body

\import [[$:/plugins/rimir/llm-connect/ui/tool-selector]]
\whitespace trim
<$reveal state={{{ [[$:/state/rimir/llm-connect/pair-edit/]addsuffix<currentTiddler>] }}} type="match" text="yes" animate="yes">
<div class="llm-pair-edit-panel">
<div class="llm-pair-edit-header">
<span class="llm-chat-panel-header-left"><span class="llm-chat-pin-wrapper"><button class="llm-chat-btn-pin">&#x1F4CC;</button><div class="llm-chat-pin-menu" style="display:none;"></div></span> Pair editing: <$text text=<<currentTiddler>>/></span>
<span class="llm-chat-panel-header-actions">
<span class="llm-chat-io-wrapper"><button class="llm-chat-btn-export tc-btn-invisible" title="Export chat to clipboard">{{$:/plugins/rimir/llm-connect/icon/export}}</button><button class="llm-chat-btn-import tc-btn-invisible" title="Import chat from clipboard">{{$:/plugins/rimir/llm-connect/icon/import}}</button></span>
<$transclude $variable="llm-tool-selector" chatTiddler={{{ [[$:/temp/rimir/llm-connect/pair-edit/]addsuffix<currentTiddler>] }}}/>
<$button set={{{ [[$:/state/rimir/llm-connect/pair-edit/]addsuffix<currentTiddler>] }}} setTo="no" class="tc-btn-invisible">&times;</$button>
</span>
</div>
<$llm-chat
  chatTiddler={{{ [[$:/temp/rimir/llm-connect/pair-edit/]addsuffix<currentTiddler>] }}}
  tiddler=<<currentTiddler>>
  systemPrompt="You are a TiddlyWiki wikitext expert helping the user edit a tiddler. You can read the current version with get_tiddler and apply changes with set_field (field: 'text'). Always show the complete updated wikitext before applying. When the user says 'apply' or 'do it', use set_field to write the changes. After writing, re-read the tiddler to confirm."
  tools="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]]"
  contextTemplate="$:/plugins/rimir/llm-connect/context-templates/pair-edit"
/>
</div>
</$reveal>
