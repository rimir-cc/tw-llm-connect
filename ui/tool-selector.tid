title: $:/plugins/rimir/llm-connect/ui/tool-selector
type: text/vnd.tiddlywiki

\procedure llm-tool-selector(chatTiddler)
\whitespace trim
<div class="llm-tool-selector-wrapper">
<$let selectorState={{{ [[$:/state/rimir/llm-connect/tool-selector/]addsuffix<chatTiddler>] }}}>
<$button class="tc-btn-invisible llm-tool-selector-btn" tooltip="Select active tools">
<$list filter="[<chatTiddler>get[llm-tools-init]else[no]!match[yes]]" variable="_">
<$action-setfield $tiddler=<<chatTiddler>> llm-tools-init="yes"/>
<$action-listops $tiddler=<<chatTiddler>> $field="llm-active-tools" $filter="[all[shadows]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]]"/>
</$list>
<$action-setfield $tiddler=<<selectorState>> text={{{ [<selectorState>get[text]match[open]then[closed]else[open]] }}}/>
<$transclude $tiddler="$:/plugins/rimir/llm-connect/icon/tools"/>
</$button>
<$reveal type="match" state=<<selectorState>> text="open" animate="yes">
<$click-outside state=<<selectorState>> closedValue="closed">
<div class="llm-tool-selector-dropdown">
<div class="llm-tool-selector-actions">
<$button class="llm-tool-selector-action-btn" tooltip="Enable all tools">
<$action-listops $tiddler=<<chatTiddler>> $field="llm-active-tools" $filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]]"/>
All
</$button>
<$button class="llm-tool-selector-action-btn" tooltip="Disable all tools">
<$action-setfield $tiddler=<<chatTiddler>> llm-active-tools=""/>
None
</$button>
<$list filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool-group]sort[group-name]]" variable="group">
<$button class="llm-tool-selector-action-btn llm-tool-selector-group-btn" tooltip={{{ [<group>get[group-description]else[Apply tool group]] }}}>
<$action-setfield $tiddler=<<chatTiddler>> llm-active-tools={{{ [<group>get[group-tools]] }}}/>
<$text text={{{ [<group>get[group-name]] }}}/>
</$button>
</$list>
</div>
<div class="llm-tool-selector-list">
<$list filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]sort[tool-name]]" variable="tool">
<label class="llm-tool-selector-item" title={{{ [<tool>get[tool-description]] }}}>
<$checkbox tiddler=<<chatTiddler>> listField="llm-active-tools" checked=<<tool>>/>&nbsp;<$text text={{{ [<tool>get[tool-name]] }}}/>
</label>
</$list>
</div>
</div>
</$click-outside>
</$reveal>
</$let>
</div>
\end
