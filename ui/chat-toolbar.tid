title: $:/plugins/rimir/llm-connect/ui/chat-toolbar
type: text/vnd.tiddlywiki

\procedure llm-chat-toolbar-left(label)
\whitespace trim
<span class="llm-chat-panel-header-left"><span class="llm-chat-pin-wrapper"><button class="llm-chat-btn-pin">&#x1F4CC;</button><div class="llm-chat-pin-menu" style="display:none;"></div></span> <<label>></span>
\end

\procedure llm-tool-selector(chatTiddler)
\whitespace trim
<div class="llm-tool-selector-wrapper">
<$let selectorState={{{ [[$:/state/rimir/llm-connect/tool-selector/]addsuffix<chatTiddler>] }}}>
<$button class="tc-btn-invisible llm-tool-selector-btn" tooltip="Select active tools">
<$list filter="[<chatTiddler>get[llm-tools-init]else[no]!match[yes]]" variable="_">
<$action-setfield $tiddler=<<chatTiddler>> llm-tools-init="yes"/>
<$action-listops $tiddler=<<chatTiddler>> $field="llm-active-tools" $filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]]"/>
</$list>
<$action-setfield $tiddler=<<selectorState>> text={{{ [<selectorState>get[text]match[open]then[closed]else[open]] }}}/>
<$transclude $tiddler="$:/plugins/rimir/llm-connect/icon/tools"/>
</$button>
<$reveal type="match" state=<<selectorState>> text="open" animate="yes">
<$click-outside state=<<selectorState>> closedValue="closed">
<div class="llm-tool-selector-dropdown">
<div class="llm-tool-selector-actions">
<$button class="llm-tool-selector-action-btn" tooltip="Enable all tools">
<$action-listops $tiddler=<<chatTiddler>> $field="llm-active-tools" $filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]]"/>
All
</$button>
<$button class="llm-tool-selector-action-btn" tooltip="Disable all tools">
<$action-setfield $tiddler=<<chatTiddler>> llm-active-tools=""/>
None
</$button>
</div>
<div class="llm-ctx-tree">
<$let all-cats={{{ [all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]get[tool-category]] +[unique[]sort[]join[ ]] }}}>
<$list filter="[enlist<all-cats>]" variable="cat">
<$let
  cat-tools={{{ [all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]] :filter[get[tool-category]match<cat>] +[format:titlelist[]join[ ]] }}}
  cat-count={{{ [enlist<cat-tools>count[]] }}}
  active-count={{{ [enlist<cat-tools>] :filter[<chatTiddler>get[llm-active-tools]enlist-input[]match<currentTiddler>] +[count[]] }}}
  state={{{ [<active-count>match[0]then[unchecked]] ~[<active-count>match<cat-count>then[checked]] ~[[indeterminate]] }}}
  collapse-state={{{ [[$:/state/rimir/llm-connect/tool-tree/]addsuffix<chatTiddler>addsuffix[/]addsuffix<cat>] }}}
  is-collapsed={{{ [<collapse-state>get[text]] ~[[closed]] }}}
>
<div class="llm-ctx-tree-node">
<$button class={{{ [[llm-ctx-cb llm-ctx-]addsuffix<state>] }}} tooltip={{{ [<cat-count>addsuffix[ tools]] }}}>
<%if [<state>match[checked]] %>
<$action-setfield $tiddler=<<chatTiddler>> llm-active-tools={{{ [<chatTiddler>get[llm-active-tools]enlist-input[]] -[enlist<cat-tools>] +[join[ ]] }}}/>
<%else%>
<$action-setfield $tiddler=<<chatTiddler>> llm-active-tools={{{ [<chatTiddler>get[llm-active-tools]enlist-input[]] [enlist<cat-tools>] +[unique[]join[ ]] }}}/>
<%endif%>
</$button>
<$button class="llm-ctx-toggle tc-btn-invisible" tooltip="Expand/collapse">
<$action-setfield $tiddler=<<collapse-state>> text={{{ [<collapse-state>get[text]match[closed]then[open]else[closed]] }}}/>
<%if [<is-collapsed>match[closed]] %>&#x25B6;<%else%>&#x25BC;<%endif%>
</$button>
<span class="llm-ctx-label"><$text text=<<cat>>/> (<$text text=<<cat-count>>/>)</span>
</div>
<$reveal type="nomatch" state=<<collapse-state>> text="closed" default="closed" animate="yes">
<div class="llm-ctx-tree-children">
<$list filter="[enlist<cat-tools>sort[tool-name]]" variable="tool">
<label class="llm-tool-selector-item" title={{{ [<tool>get[tool-description]] }}}>
<$checkbox tiddler=<<chatTiddler>> listField="llm-active-tools" checked=<<tool>>/>&nbsp;<$text text={{{ [<tool>get[tool-name]] }}}/>
</label>
</$list>
</div>
</$reveal>
</$let>
</$list>
</$let>
</div>
</div>
</$click-outside>
</$reveal>
</$let>
</div>
\end

\procedure llm-ctx-tree-node(prefix, chatTiddler, all-keys, depth:"0")
\whitespace trim
<$let children={{{ [enlist<all-keys>prefix<prefix>removeprefix<prefix>] :map[split[/]first[]] +[!is[blank]unique[]sort[]join[ ]] }}}
  next-depth={{{ [<depth>add[1]] }}}
>
<$list filter="[enlist<children>]" variable="segment">
<$let
  node-key={{{ [<prefix>match[]then<segment>] ~[<prefix>addsuffix<segment>] }}}
  node-prefix={{{ [<node-key>addsuffix[/]] }}}
  descendants={{{ [enlist<all-keys>prefix<node-prefix>] [enlist<all-keys>match<node-key>] +[unique[]join[ ]] }}}
  desc-count={{{ [enlist<descendants>count[]] }}}
  active-count={{{ [enlist<descendants>] :filter[<chatTiddler>get[llm-help-context]enlist-input[]match<currentTiddler>] +[count[]] }}}
  has-children={{{ [enlist<all-keys>prefix<node-prefix>first[]] }}}
  state={{{ [<active-count>match[0]then[unchecked]] ~[<active-count>match<desc-count>then[checked]] ~[[indeterminate]] }}}
  collapse-state={{{ [[$:/state/rimir/llm-connect/ctx-tree/]addsuffix<chatTiddler>addsuffix[/]addsuffix<node-key>] }}}
  default-collapsed={{{ [<depth>compare:integer:gteq[1]then[closed]] }}}
  is-collapsed={{{ [<collapse-state>get[text]] ~[<default-collapsed>] }}}
  display-label={{{ [<segment>search-replace:g[_],[ ]] }}}
>
<div class="llm-ctx-tree-node">
<$button class={{{ [[llm-ctx-cb llm-ctx-]addsuffix<state>] }}} tooltip={{{ [<desc-count>addsuffix[ context keys]] }}}>
<%if [<state>match[checked]] %>
<$action-setfield $tiddler=<<chatTiddler>> llm-help-context={{{ [<chatTiddler>get[llm-help-context]enlist-input[]] -[enlist<descendants>] +[join[ ]] }}}/>
<%else%>
<$action-setfield $tiddler=<<chatTiddler>> llm-help-context={{{ [<chatTiddler>get[llm-help-context]enlist-input[]] [enlist<descendants>] +[unique[]sort[]join[ ]] }}}/>
<%endif%>
</$button>
<%if [<has-children>minlength[1]] %>
<$button class="llm-ctx-toggle tc-btn-invisible" tooltip="Expand/collapse">
<$action-setfield $tiddler=<<collapse-state>> text={{{ [<collapse-state>get[text]match[closed]then[open]else[closed]] }}}/>
<%if [<is-collapsed>match[closed]] %>&#x25B6;<%else%>&#x25BC;<%endif%>
</$button>
<%endif%>
<span class="llm-ctx-label"><$text text=<<display-label>>/></span>
</div>
<%if [<has-children>minlength[1]] %>
<$reveal type="nomatch" state=<<collapse-state>> text="closed" default=<<default-collapsed>> animate="yes">
<div class="llm-ctx-tree-children">
<$transclude $variable="llm-ctx-tree-node" prefix=<<node-prefix>> chatTiddler=<<chatTiddler>> all-keys=<<all-keys>> depth=<<next-depth>>/>
</div>
</$reveal>
<%endif%>
</$let>
</$list>
</$let>
\end

\procedure llm-context-selector(chatTiddler)
\whitespace trim
<%if [[$:/plugins/rimir/llm-help]has[plugin-type]] %>
<$let all-ctx-keys={{{ [all[shadows+tiddlers]tag[$:/tags/rimir/llm-help/page]get[llm-help-context]enlist-input[]] +[unique[]sort[]join[ ]] }}}>
<%if [<all-ctx-keys>minlength[1]] %>
<div class="llm-context-selector-wrapper">
<$let selectorState={{{ [[$:/state/rimir/llm-connect/context-selector/]addsuffix<chatTiddler>] }}}>
<$button class="tc-btn-invisible llm-tool-selector-btn" tooltip="Select help context">
<$action-setfield $tiddler=<<selectorState>> text={{{ [<selectorState>get[text]match[open]then[closed]else[open]] }}}/>
<$transclude $tiddler="$:/plugins/rimir/llm-connect/icon/help-context"/>
</$button>
<$reveal type="match" state=<<selectorState>> text="open" animate="yes">
<$click-outside state=<<selectorState>> closedValue="closed">
<div class="llm-tool-selector-dropdown">
<div class="llm-tool-selector-actions">
<$button class="llm-tool-selector-action-btn" tooltip="Enable all context">
<$action-setfield $tiddler=<<chatTiddler>> llm-help-context=<<all-ctx-keys>>/>
All
</$button>
<$button class="llm-tool-selector-action-btn" tooltip="Clear all context">
<$action-setfield $tiddler=<<chatTiddler>> llm-help-context=""/>
None
</$button>
<$list filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/context-group]sort[group-name]]" variable="group">
<$button class="llm-tool-selector-action-btn llm-tool-selector-group-btn" tooltip={{{ [<group>get[group-description]else[Apply context group]] }}}>
<$action-setfield $tiddler=<<chatTiddler>> llm-help-context={{{ [<group>get[group-contexts]] }}}/>
<$text text={{{ [<group>get[group-name]] }}}/>
</$button>
</$list>
</div>
<div class="llm-ctx-tree">
<$transclude $variable="llm-ctx-tree-node" prefix="" chatTiddler=<<chatTiddler>> all-keys=<<all-ctx-keys>>/>
</div>
</div>
</$click-outside>
</$reveal>
</$let>
</div>
<%endif%>
</$let>
<%endif%>
\end

\procedure llm-chat-toolbar-actions(chatTiddler)
\whitespace trim
<span class="llm-chat-io-wrapper"><button class="llm-chat-btn-export tc-btn-invisible" title="Export chat to clipboard">{{$:/plugins/rimir/llm-connect/icon/export}}</button><button class="llm-chat-btn-import tc-btn-invisible" title="Import chat from clipboard">{{$:/plugins/rimir/llm-connect/icon/import}}</button></span>
<$transclude $variable="llm-tool-selector" chatTiddler=<<chatTiddler>>/>
<$transclude $variable="llm-context-selector" chatTiddler=<<chatTiddler>>/>
\end
