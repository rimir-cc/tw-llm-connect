\import [[$:/plugins/rimir/llm-connect/ui/tool-selector]]
\procedure llm-chat-view()
<div class="llm-tool-selector-bar">
<span class="llm-chat-pin-wrapper"><button class="llm-chat-btn-pin">&#x1F4CC;</button><div class="llm-chat-pin-menu" style="display:none;"></div></span>
<<llm-tool-selector "$:/temp/rimir/llm-connect/default-chat">>
</div>
<$llm-chat
  chatTiddler="$:/temp/rimir/llm-connect/default-chat"
  tools="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]]"
/>
\end

<<llm-chat-view>>
