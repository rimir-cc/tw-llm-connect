\import [[$:/plugins/rimir/llm-connect/ui/chat-toolbar]]
\procedure llm-chat-view()
<div class="llm-tool-selector-bar">
<<llm-chat-toolbar-left>>
<<llm-chat-toolbar-actions "$:/temp/rimir/llm-connect/default-chat">>
</div>
<$llm-chat
  chatTiddler="$:/temp/rimir/llm-connect/default-chat"
  tools="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]]"
  defaultContext="rimir/typed tw-gotchas shortcuts"
/>
\end

<<llm-chat-view>>
