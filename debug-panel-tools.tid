title: $:/plugins/rimir/llm-connect/debug-panel-tools
tags: $:/tags/rimir/llm-connect/debug-panel
panel-name: Active Tools (int. data)
panel-icon: 🔧
panel-order: 55
type: text/vnd.tiddlywiki

\whitespace trim

<$let
  init={{{ [<chatTiddler>get[llm-tools-init]else[no]] }}}
  toolFilter={{{ [<init>match[yes]then[enlist]else[tag]] }}}
>
<div class="llm-chat-debug-tools-state">
<%if [<init>match[yes]] %>
<$let count={{{ [<chatTiddler>get[llm-active-tools]enlist-input[]count[]] }}}>
<strong><$text text=<<count>>/>&nbsp;active tools</strong>&nbsp;(explicit)
<$list filter="[<chatTiddler>get[llm-active-tools]enlist-input[]sort[]]" variable="toolTid">
<$let
  tname={{{ [<toolTid>get[tool-name]else<toolTid>] }}}
  tcat={{{ [<toolTid>get[tool-category]else[-]] }}}
  ttier={{{ [<toolTid>get[tool-model-tier]else[default]] }}}
>
<div class="llm-chat-debug-tool-entry"><code><$text text=<<tname>>/></code> <span class="llm-chat-debug-tool-meta">[<$text text=<<tcat>>/>] tier:<$text text=<<ttier>>/></span></div>
</$let>
</$list>
</$let>
<%else%>
<$let count={{{ [all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]count[]] }}}>
<strong><$text text=<<count>>/>&nbsp;active tools</strong>&nbsp;(default — all)
<$list filter="[all[shadows+tiddlers]tag[$:/tags/rimir/llm-connect/tool]!field:tool-enabled[no]sort[tool-name]]" variable="toolTid">
<$let
  tname={{{ [<toolTid>get[tool-name]else<toolTid>] }}}
  tcat={{{ [<toolTid>get[tool-category]else[-]] }}}
  ttier={{{ [<toolTid>get[tool-model-tier]else[default]] }}}
>
<div class="llm-chat-debug-tool-entry"><code><$text text=<<tname>>/></code> <span class="llm-chat-debug-tool-meta">[<$text text=<<tcat>>/>] tier:<$text text=<<ttier>>/></span></div>
</$let>
</$list>
</$let>
<%endif%>
</div>
</$let>
